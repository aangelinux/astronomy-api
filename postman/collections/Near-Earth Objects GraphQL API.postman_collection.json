              ]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data.login) {",
                  "  // Try to get token from response header",
                  "  const authHeader = pm.response.headers.get('Authorization');",
                  "  if (authHeader) {",
                  "    pm.collectionVariables.set('token', authHeader.replace('Bearer ', ''));",
                  "  }",
                  "}",
                  "pm.test(\"Login successful\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(response.data.login).to.have.property('id');",
                  "});"
                ]
              }
            }
          ],
